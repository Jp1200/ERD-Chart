{
  "name": "erd-maker",
  "version": "1.0.0",
  "description": "Terminal-launchable interactive ERD Diagram Maker and database schema visualizer",
  "type": "module",
  "bin": {
    "erd-maker": "./bin/index.js"
  },
  "scripts": {
    "start": "node bin/index.js",
    "build": "npm run build --prefix frontend",
    "dev": "concurrently \"npm run dev --prefix frontend\" \"node bin/index.js --dev\"",
    "install-all": "npm install && npm install --prefix frontend"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "erd",
    "database",
    "schema",
    "visualizer",
    "sql",
    "diagram"
  ],
  "author": "Antigravity",
  "license": "MIT"
}
